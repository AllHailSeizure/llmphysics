{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "llmphysics-bot",
  "server": {
    "entry": "index.cjs"
  },
  "dev": {
    "subreddit": "llmphysics_dev"
  },
  "permissions": {
    "http": {
      "domains": ["en.wikipedia.org", "generativelanguage.googleapis.com", "zenodo.org", "eimdgqymjwfljtapnuyl.supabase.co"]
    },
    "redis": true,
    "reddit": {
      "enable": true,
      "asUser": ["SUBMIT_COMMENT", "SUBMIT_POST"],
      "scope": "moderator"
    }
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/app-install",
    "onAppUpgrade": "/internal/triggers/app-upgrade",
    "onPostSubmit": "/internal/triggers/post-submit",
    "onPostFlairUpdate": "/internal/triggers/post-flair-update",
    "onCommentCreate": "/internal/triggers/comment-create",
    "onPostReport": "/internal/triggers/post-report",
    "onCommentReport": "/internal/triggers/comment-report",
    "onModAction": "/internal/triggers/mod-action",
    "onPostDelete": "/internal/triggers/post-delete",
    "onModMail": "/internal/triggers/mod-mail"
  },
  "settings": {
    "global": {
      "geminiApiKey": {
        "type": "string",
        "label": "Gemini API key",
        "helpText": "Google Gemini API key used by the !define command for term resolution.",
        "isSecret": true
      },
      "supabaseUrl": {
        "type": "string",
        "label": "Supabase project URL",
        "helpText": "https://YOUR_PROJECT.supabase.co — used for the async PDF review queue.",
        "isSecret": false
      },
      "supabaseServiceRoleKey": {
        "type": "string",
        "label": "Supabase service role key",
        "helpText": "Service role key for the review_jobs table. Keep secret.",
        "isSecret": true
      }
    }
  },
  "scripts": {
    "build": "npm run build"
  }
}
