{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "llmphysics-bot",
  "server": {
    "entry": "index.js"
  },
  "dev":{
    "subreddit": "llmphysics_dev"
  },
  "permissions": {
    "http": {
      "domains": ["en.wikipedia.org", "generativelanguage.googleapis.com"]
    },
    "redis": true,
    "reddit": {
      "enable": true
    }
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/app-install",
    "onAppUpgrade": "/internal/triggers/app-upgrade",
    "onPostSubmit": "/internal/triggers/post-submit",
    "onCommentCreate": "/internal/triggers/comment-create",
    "onPostReport": "/internal/triggers/post-report",
    "onCommentReport": "/internal/triggers/comment-report",
    "onModAction": "/internal/triggers/mod-action",
    "onModMail": "/internal/triggers/mod-mail"
  },
  "menu": {
    "items": [
      {
        "label": "Chain Mop",
        "description": "Remove and/or lock this comment chain",
        "forUserType": "moderator",
        "location": "comment",
        "endpoint": "/internal/menu/chain-mop"
      },
      {
        "label": "Apply saved response",
        "description": "Post a saved general response to this content",
        "forUserType": "moderator",
        "location": ["comment", "post"],
        "endpoint": "/internal/menu/apply-saved-response",
        "postFilter": "none"
      },
      {
        "label": "Saved responses",
        "description": "Add, edit, or delete saved general responses",
        "forUserType": "moderator",
        "location": "subreddit",
        "endpoint": "/internal/menu/saved-responses",
        "postFilter": "none"
      },
      {
        "label": "Bot Settings",
        "description": "Edit bot settings (depth cap, signature, appeal URL, etc.)",
        "forUserType": "moderator",
        "location": "subreddit",
        "endpoint": "/internal/menu/bot-settings"
      }
    ]
  },
  "forms": {
    "chain-mop":                  "/internal/forms/chain-mop",
    "saved-response-manage":      "/internal/forms/saved-response/manage",
    "saved-response-select":      "/internal/forms/saved-response/step2",
    "saved-response-apply":       "/internal/forms/saved-response/apply",
    "saved-response-add":         "/internal/forms/saved-response/add",
    "saved-response-edit-select": "/internal/forms/saved-response/edit-select",
    "saved-response-edit-apply":  "/internal/forms/saved-response/edit-apply",
    "saved-response-delete":      "/internal/forms/saved-response/delete",
    "bot-settings":               "/internal/forms/bot-settings"
  },
  "settings": {
    "global": {
      "geminiApiKey": {
        "type": "string",
        "label": "Gemini API key",
        "helpText": "Google Gemini API key used by the !define command for term resolution.",
        "isSecret": true
      }
    },
    "subreddit": {
      "botSignature": {
        "type": "paragraph",
        "label": "General — Bot signature",
        "helpText": "Appended to all bot comments. Leave blank for no signature.",
        "defaultValue": "^I ^am ^a ^bot. ^This ^action ^was ^performed ^automatically. ^Contact ^the ^moderators ^if ^you ^have ^questions."
      },
      "depthCap": {
        "type": "number",
        "label": "Chain Moderation — Maximum comment chain depth",
        "helpText": "Lock comment chains that reach this depth. Set to 0 to disable. Default: 10.",
        "defaultValue": 10
      },
      "depthCapNotice": {
        "type": "paragraph",
        "label": "Chain Moderation — Depth cap notice",
        "helpText": "Message the bot posts when a comment hits the depth cap.",
        "defaultValue": "This comment has reached the maximum comment depth and locked. The comment was submitted for review and if found to be productive will be unlocked."
      }
    }
  },
  "scripts": {
    "build": "npm run build"
  }
}
